# obi-wan-core configuration
# Copy to ~/.config/obi-wan-core/config.yaml and edit.

claude_binary: /home/leo/.local/bin/claude
state_dir: /home/leo/.local/state/obi-wan-core
model: sonnet

fallback:
  enabled: true
  tiers:
    - base_url: https://api.z.ai/api/anthropic
      api_key_env: ZAI_API_KEY
      model: glm-5.1
      label: GLM
    - base_url: http://localhost:11434
      auth_token: ollama
      model: gemma4:latest
      label: Ollama

channels:
  telegram:
    enabled: true
    allow_from:
      - "YOUR_TELEGRAM_USER_ID"
  watch:
    enabled: true
    webhook_key: "set-via-env-OBI_WAN_CORE_WEBHOOK_KEY"
  r1:
    enabled: false
